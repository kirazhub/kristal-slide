# Derleme çıktıları
dist/
build/
*.log

# IDE/Editör dosyaları
.vscode/
.idea/
*.swp
*.swo

# macOS sistem dosyaları
.DS_Store
.AppleDouble
.LSOverride

# Geçici dosyalar
tmp/
temp/
*.tmp
